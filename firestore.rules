rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Gallery data is written by Cloud Functions (service account bypasses rules)
    match /ad_creatives/{document} {
      allow read: if true;
      allow write: if false;
    }
    // Frontend writes audit logs when manually triggering a pipeline sync
    match /pipeline_logs/{document} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
